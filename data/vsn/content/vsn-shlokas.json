{"text":"vsn","total":108,"shlokas":[{"s":1,"p1":{"sa":"विश्वं विष्णुर्वषट्कारः","ro":"viśvaṃ viṣṇurvaṣaṭkāraḥ","te":"విశ్వం విష్ణుర్వషట్కారః"},"p2":{"sa":"भूतभव्यभवत्प्रभुः","ro":"bhūtabhavyabhavatprabhuḥ","te":"భూతభవ్యభవత్ప్రభుః"},"p3":{"sa":"भूतकृद्भूतभृद्भावः","ro":"Bhūtakṛdbhūtabhṛdbhāvaḥ","te":"భూతకృద్భూతభృద్భావః"},"p4":{"sa":"भूतात्मा भूतभावनः","ro":"bhūtātmā bhūtabhāvanaḥ","te":"భూతాత్మా భూతభావనః"}},{"s":2,"p1":{"sa":"पूतात्मा परमात्मा च","ro":"Pūtātmā paramātmā ca","te":"పూతాత్మా పరమాత్మా చ"},"p2":{"sa":"मुक्तानां परमा गतिः","ro":"muktānāṃ paramā gatiḥ","te":"ముక్తానాం పరమా గతిః"},"p3":{"sa":"अव्ययः पुरुषः साक्षी","ro":"Avyayaḥ puruṣaḥ sākṣī","te":"అవ్యయః పురుషః సాక్షీ"},"p4":{"sa":"क्षेत्रज्ञोऽक्षर एव च","ro":"kṣetrajño'kṣara eva ca","te":"క్షేత్రజ్ఞోఽక్షర ఏవ చ"}},{"s":3,"p1":{"sa":"योगो योगविदां नेता","ro":"Yogo yogavidāṃ netā","te":"యోగో యోగవిదాం నేతా"},"p2":{"sa":"प्रधानपुरुषेश्वरः","ro":"pradhānapuruṣeśvaraḥ","te":"ప్రధానపురుషేశ్వరః"},"p3":{"sa":"नारसिंहवपुः श्रीमान्","ro":"Nārasiṃhavapuḥ śrīmān","te":"నారసింహవపుః శ్రీమాన్"},"p4":{"sa":"केशवः पुरुषोत्तमः","ro":"keśavaḥ puruṣottamaḥ","te":"కేశవః పురుషోత్తమః"}},{"s":4,"p1":{"sa":"सर्वः शर्वः शिवः स्थाणुः","ro":"Sarvaḥ śarvaḥ śivaḥ sthāṇuḥ","te":"సర్వః శర్వః శివః స్థాణుః"},"p2":{"sa":"भूतादिर्निधिरव्ययः","ro":"bhūtādirnidhiravyayaḥ","te":"భూతాదిర్నిధిరవ్యయః"},"p3":{"sa":"सम्भवो भावनो भर्ता","ro":"Sambhavo bhāvano bhartā","te":"సమ్భవో భావనో భర్తా"},"p4":{"sa":"प्रभवः प्रभुरीश्वरः","ro":"prabhavaḥ prabhurīśvaraḥ","te":"ప్రభవః ప్రభురీశ్వరః"}},{"s":5,"p1":{"sa":"स्वयम्भूः शम्भुरादित्यः","ro":"Svayambhūḥ śambhurādityaḥ","te":"స్వయమ్భూః శమ్భురాదిత్యః"},"p2":{"sa":"पुष्कराक्षो महास्वनः","ro":"puṣkarākṣo mahāsvanaḥ","te":"పుష్కరాక్షో మహాస్వనః"},"p3":{"sa":"अनादिनिधनो धाता","ro":"Anādinidhano dhātā","te":"అనాదినిధనో ధాతా"},"p4":{"sa":"विधाता धातुरुत्तमः","ro":"vidhātā dhāturuttamaḥ","te":"విధాతా ధాతురుత్తమః"}},{"s":6,"p1":{"sa":"अप्रमेयो हृषीकेशः","ro":"Aprameyo hṛṣīkeśaḥ","te":"అప్రమేయో హృషీకేశః"},"p2":{"sa":"पद्मनाभोऽमरप्रभुः","ro":"padmanābho'maraprabhuḥ","te":"పద్మనాభోఽమరప్రభుః"},"p3":{"sa":"विश्वकर्मा मनुस्त्वष्टा","ro":"Viśvakarmā manustvaṣṭā","te":"విశ్వకర్మా మనుస్త్వష్టా"},"p4":{"sa":"स्थविष्ठः स्थविरो ध्रुवः","ro":"sthaviṣṭhaḥ sthaviro dhruvaḥ","te":"స్థవిష్ఠః స్థవిరో ధ్రువః"}},{"s":7,"p1":{"sa":"अग्राह्यः शाश्वतः कृष्णः","ro":"Agrāhyaḥ śāśvataḥ kṛṣṇaḥ","te":"అగ్రాహ్యః శాశ్వతః కృష్ణః"},"p2":{"sa":"लोहिताक्षः प्रतर्दनः","ro":"lohitākṣaḥ pratardanaḥ","te":"లోహితాక్షః ప్రతర్దనః"},"p3":{"sa":"प्रभूतस्त्रिककुब्धाम","ro":"Prabhūtastrikakubdhāma","te":"ప్రభూతస్త్రికకుబ్ధామ"},"p4":{"sa":"पवित्रं मङ्गलं परम्","ro":"pavitraṃ maṅgalaṃ param","te":"పవిత్రం మఙ్గలం పరమ్"}},{"s":8,"p1":{"sa":"ईशानः प्राणदः प्राणः","ro":"Īśānaḥ prāṇadaḥ prāṇaḥ","te":"ఈశానః ప్రాణదః ప్రాణః"},"p2":{"sa":"ज्येष्ठः श्रेष्ठः प्रजापतिः","ro":"jyeṣṭhaḥ śreṣṭhaḥ prajāpatiḥ","te":"జ్యేష్ఠః శ్రేష్ఠః ప్రజాపతిః"},"p3":{"sa":"हिरण्यगर्भो भूगर्भः","ro":"Hiraṇyagarbho bhūgarbhaḥ","te":"హిరణ్యగర్భో భూగర్భః"},"p4":{"sa":"माधवो मधुसूदनः","ro":"mādhavo madhusūdanaḥ","te":"మాధవో మధుసూదనః"}},{"s":9,"p1":{"sa":"ईश्वरो विक्रमी धन्वी","ro":"Īśvaro vikramī dhanvī","te":"ఈశ్వరో విక్రమీ ధన్వీ"},"p2":{"sa":"मेधावी विक्रमः क्रमः","ro":"medhāvī vikramaḥ kramaḥ","te":"మేధావీ విక్రమః క్రమః"},"p3":{"sa":"अनुत्तमो दुराधर्षः","ro":"Anuttamo durādharṣaḥ","te":"అనుత్తమో దురాధర్షః"},"p4":{"sa":"कृतज्ञः कृतिरात्मवान्","ro":"kṛtajñaḥ kṛtirātmavān","te":"కృతజ్ఞః కృతిరాత్మవాన్"}},{"s":10,"p1":{"sa":"सुरेशः शरणं शर्म","ro":"Sureśaḥ śaraṇaṃ śarma","te":"సురేశః శరణం శర్మ"},"p2":{"sa":"विश्वरेताः प्रजाभवः","ro":"viśvaretāḥ prajābhavaḥ","te":"విశ్వరేతాః ప్రజాభవః"},"p3":{"sa":"अहः संवत्सरो व्यालः","ro":"Ahaḥ saṃvatsaro vyālaḥ","te":"అహః సంవత్సరో వ్యాలః"},"p4":{"sa":"प्रत्ययः सर्वदर्शनः","ro":"pratyayaḥ sarvadarśanaḥ","te":"ప్రత్యయః సర్వదర్శనః"}},{"s":11,"p1":{"sa":"अजः सर्वेश्वरः सिद्धः","ro":"Ajaḥ sarveśvaraḥ siddhaḥ","te":"అజః సర్వేశ్వరః సిద్ధః"},"p2":{"sa":"सिद्धिः सर्वादिरच्युतः","ro":"siddhiḥ sarvādiracyutaḥ","te":"సిద్ధిః సర్వాదిరచ్యుతః"},"p3":{"sa":"वृषाकपिरमेयात्मा","ro":"Vṛṣākapirameyātmā","te":"వృషాకపిరమేయాత్మా"},"p4":{"sa":"सर्वयोगविनिःसृतः","ro":"sarvayogaviniḥsṛtaḥ","te":"సర్వయోగవినిఃసృతః"}},{"s":12,"p1":{"sa":"वसुर्वसुमनाः सत्यः","ro":"Vasurvasumanāḥ satyaḥ","te":"వసుర్వసుమనాః సత్యః"},"p2":{"sa":"समात्मासम्मितः समः","ro":"samātmāsammitaḥ samaḥ","te":"సమాత్మాసమ్మితః సమః"},"p3":{"sa":"अमोघः पुण्डरीकाक्षः","ro":"Amoghaḥ puṇḍarīkākṣaḥ","te":"అమోఘః పుణ్డరీకాక్షః"},"p4":{"sa":"वृषकर्मा वृषाकृतिः","ro":"vṛṣakarmā vṛṣākṛtiḥ","te":"వృషకర్మా వృషాకృతిః"}},{"s":13,"p1":{"sa":"रुद्रो बहुशिरा बभ्रुः","ro":"Rudro bahuśirā babhruḥ","te":"రుద్రో బహుశిరా బభ్రుః"},"p2":{"sa":"विश्वयोनिः शुचिश्रवाः","ro":"viśvayoniḥ śuciśravāḥ","te":"విశ్వయోనిః శుచిశ్రవాః"},"p3":{"sa":"अमृतः शाश्वतस्थाणुः","ro":"Amṛtaḥ śāśvatasthāṇuḥ","te":"అమృతః శాశ్వతస్థాణుః"},"p4":{"sa":"वरारोहो महातपाः","ro":"varāroho mahātapāḥ","te":"వరారోహో మహాతపాః"}},{"s":14,"p1":{"sa":"सर्वगः सर्वविद्भानुः","ro":"Sarvagaḥ sarvavidbhānuḥ","te":"సర్వగః సర్వవిద్భానుః"},"p2":{"sa":"विष्वक्सेनो जनार्दनः","ro":"viṣvakseno janārdanaḥ","te":"విష్వక్సేనో జనార్దనః"},"p3":{"sa":"वेदो वेदविदव्यङ्गः","ro":"Vedo vedavidavyaṅgaḥ","te":"వేదో వేదవిదవ్యఙ్గః"},"p4":{"sa":"वेदाङ्गो वेदवित् कविः","ro":"vedāṅgo vedavit kaviḥ","te":"వేదాఙ్గో వేదవిత్ కవిః"}},{"s":15,"p1":{"sa":"लोकाध्यक्षः सुराध्यक्षः","ro":"Lokādhyakṣaḥ surādhyakṣaḥ","te":"లోకాధ్యక్షః సురాధ్యక్షః"},"p2":{"sa":"धर्माध्यक्षः कृताकृतः","ro":"dharmādhyakṣaḥ kṛtākṛtaḥ","te":"ధర్మాధ్యక్షః కృతాకృతః"},"p3":{"sa":"चतुरात्मा चतुर्व्यूहः","ro":"Caturātmā caturvyūhaḥ","te":"చతురాత్మా చతుర్వ్యూహః"},"p4":{"sa":"चतुर्दष्ट्रश्चतुर्भुजः","ro":"caturdaṣṭraścaturbhujaḥ","te":"చతుర్దష్ట్రశ్చతుర్భుజః"}},{"s":16,"p1":{"sa":"भ्राजिष्णुर्भोजनं भोक्ता","ro":"Bhrājiṣṇurbhojanaṃ bhoktā","te":"భ్రాజిష్ణుర్భోజనం భోక్తా"},"p2":{"sa":"सहिष्णुर्जगदादिजः","ro":"sahiṣṇurjagadādijaḥ","te":"సహిష్ణుర్జగదాదిజః"},"p3":{"sa":"अनघो विजयो जेता","ro":"Anagho vijayo jetā","te":"అనఘో విజయో జేతా"},"p4":{"sa":"विश्वयोनिः पुनर्वसुः","ro":"viśvayoniḥ punarvasuḥ","te":"విశ్వయోనిః పునర్వసుః"}},{"s":17,"p1":{"sa":"उपेन्द्रो वामनः प्रांशुः","ro":"Upendro vāmanaḥ prāṃśuḥ","te":"ఉపేన్ద్రో వామనః ప్రాంశుః"},"p2":{"sa":"अमोघः शुचिरूर्जितः","ro":"amoghaḥ śucirūrjitaḥ","te":"అమోఘః శుచిరూర్జితః"},"p3":{"sa":"अतीन्द्रः सङ्ग्रहः सर्गः","ro":"Atīndraḥ saṅgrahaḥ sargaḥ","te":"అతీన్ద్రః సఙ్గ్రహః సర్గః"},"p4":{"sa":"धृतात्मा नियमो यमः","ro":"dhṛtātmā niyamo yamaḥ","te":"ధృతాత్మా నియమో యమః"}},{"s":18,"p1":{"sa":"वेद्यो वैद्यः सदायोगी","ro":"Vedyo vaidyaḥ sadāyogī","te":"వేద్యో వైద్యః సదాయోగీ"},"p2":{"sa":"वीरहा माधवो मधुः","ro":"vīrahā mādhavo madhuḥ","te":"వీరహా మాధవో మధుః"},"p3":{"sa":"अतीन्द्रियो महामायः","ro":"Atīndriyo mahāmāyaḥ","te":"అతీన్ద్రియో మహామాయః"},"p4":{"sa":"महोत्साहो महाबलः","ro":"mahotsāho mahābalaḥ","te":"మహోత్సాహో మహాబలః"}},{"s":19,"p1":{"sa":"महाबुद्धिर्महावीर्यः","ro":"Mahābuddhirmahāvīryaḥ","te":"మహాబుద్ధిర్మహావీర్యః"},"p2":{"sa":"महाशक्तिर्महाद्युतिः","ro":"mahāśaktirmahādyutiḥ","te":"మహాశక్తిర్మహాద్యుతిః"},"p3":{"sa":"अनिर्देश्यवपुः श्रीमान्","ro":"Anirdeśyavapuḥ śrīmān","te":"అనిర్దేశ్యవపుః శ్రీమాన్"},"p4":{"sa":"अमेयात्मा महाद्रिधृक्","ro":"ameyātmā mahādridhṛk","te":"అమేయాత్మా మహాద్రిధృక్"}},{"s":20,"p1":{"sa":"महेष्वासो महीभर्ता","ro":"Maheṣvāso mahībhartā","te":"మహేష్వాసో మహీభర్తా"},"p2":{"sa":"श्रीनिवासः सतां गतिः","ro":"śrīnivāsaḥ satāṃ gatiḥ","te":"శ్రీనివాసః సతాం గతిః"},"p3":{"sa":"अनिरुद्धः सुरानन्दः","ro":"Aniruddhaḥ surānandaḥ","te":"అనిరుద్ధః సురానన్దః"},"p4":{"sa":"गोविन्दो गोविदां पतिः","ro":"govindo govidāṃ patiḥ","te":"గోవిన్దో గోవిదాం పతిః"}},{"s":21,"p1":{"sa":"मरीचिर्दमनो हंसः","ro":"Marīcirdamano haṃsaḥ","te":"మరీచిర్దమనో హంసః"},"p2":{"sa":"सुपर्णो भुजगोत्तमः","ro":"suparṇo bhujagottamaḥ","te":"సుపర్ణో భుజగోత్తమః"},"p3":{"sa":"हिरण्यनाभः सुतपाः","ro":"Hiraṇyanābhaḥ sutapāḥ","te":"హిరణ్యనాభః సుతపాః"},"p4":{"sa":"पद्मनाभः प्रजापतिः","ro":"padmanābhaḥ prajāpatiḥ","te":"పద్మనాభః ప్రజాపతిః"}},{"s":22,"p1":{"sa":"अमृत्युः सर्वदृक् सिंहः","ro":"Amṛtyuḥ sarvadṛk siṃhaḥ","te":"అమృత్యుః సర్వదృక్ సింహః"},"p2":{"sa":"सन्धाता सन्धिमान् स्थिरः","ro":"sandhātā sandhimān sthiraḥ","te":"సన్ధాతా సన్ధిమాన్ స్థిరః"},"p3":{"sa":"अजो दुर्मर्षणः शास्ता","ro":"Ajo durmarṣaṇaḥ śāstā","te":"అజో దుర్మర్షణః శాస్తా"},"p4":{"sa":"विश्रुतात्मा सुरारिहा","ro":"viśrutātmā surārihā","te":"విశ్రుతాత్మా సురారిహా"}},{"s":23,"p1":{"sa":"गुरुर्गुरुतमो धाम","ro":"Gururgurutamo dhāma","te":"గురుర్గురుతమో ధామ"},"p2":{"sa":"सत्यः सत्यपराक्रमः","ro":"satyaḥ satyaparākramaḥ","te":"సత్యః సత్యపరాక్రమః"},"p3":{"sa":"निमिषोऽनिमिषः स्रग्वी","ro":"Nimiṣo'nimiṣaḥ sragvī","te":"నిమిషోఽనిమిషః స్రగ్వీ"},"p4":{"sa":"वाचस्पतिरुदारधीः","ro":"vācaspatirudāradhīḥ","te":"వాచస్పతిరుదారధీః"}},{"s":24,"p1":{"sa":"अग्रणीर्ग्रामणीः श्रीमान्","ro":"Agraṇīrgrāmaṇīḥ śrīmān","te":"అగ్రణీర్గ్రామణీః శ్రీమాన్"},"p2":{"sa":"न्यायो नेता समीरणः","ro":"nyāyo netā samīraṇaḥ","te":"న్యాయో నేతా సమీరణః"},"p3":{"sa":"सहस्रमूर्धा विश्वात्मा","ro":"Sahasramūrdhā viśvātmā","te":"సహస్రమూర్ధా విశ్వాత్మా"},"p4":{"sa":"सहस्राक्षः सहस्रपात्","ro":"sahasrākṣaḥ sahasrapāt","te":"సహస్రాక్షః సహస్రపాత్"}},{"s":25,"p1":{"sa":"आवर्तनो निवृत्तात्मा","ro":"Āvartano nivṛttātmā","te":"ఆవర్తనో నివృత్తాత్మా"},"p2":{"sa":"संवृतः सम्प्रमर्दनः","ro":"saṃvṛtaḥ sampramardanaḥ","te":"సంవృతః సమ్ప్రమర్దనః"},"p3":{"sa":"अहः संवर्तको वह्निः","ro":"Ahaḥ saṃvartako vahniḥ","te":"అహః సంవర్తకో వహ్నిః"},"p4":{"sa":"अनिलो धरणीधरः","ro":"anilo dharaṇīdharaḥ","te":"అనిలో ధరణీధరః"}},{"s":26,"p1":{"sa":"सुप्रसादः प्रसन्नात्मा","ro":"Suprasādaḥ prasannātmā","te":"సుప్రసాదః ప్రసన్నాత్మా"},"p2":{"sa":"विश्वधृग्विश्वभुग्विभुः","ro":"viśvadhṛgviśvabhugvibhuḥ","te":"విశ్వధృగ్విశ్వభుగ్విభుః"},"p3":{"sa":"सत्कर्ता सत्कृतः साधुः","ro":"Satkartā satkṛtaḥ sādhuḥ","te":"సత్కర్తా సత్కృతః సాధుః"},"p4":{"sa":"जह्नुर्नारायणो नरः","ro":"jahnurnārāyaṇo naraḥ","te":"జహ్నుర్నారాయణో నరః"}},{"s":27,"p1":{"sa":"असङ्ख्येयोऽप्रमेयात्मा","ro":"Asaṅkhyeyo'prameyātmā","te":"అసఙ్ఖ్యేయోఽప్రమేయాత్మా"},"p2":{"sa":"विशिष्टः शिष्टकृच्छुचिः","ro":"viśiṣṭaḥ śiṣṭakṛcchuciḥ","te":"విశిష్టః శిష్టకృచ్ఛుచిః"},"p3":{"sa":"सिद्धार्थः सिद्धसङ्कल्पः","ro":"Siddhārthaḥ siddhasaṅkalpaḥ","te":"సిద్ధార్థః సిద్ధసఙ్కల్పః"},"p4":{"sa":"सिद्धिदः सिद्धिसाधनः","ro":"siddhidaḥ siddhisādhanaḥ","te":"సిద్ధిదః సిద్ధిసాధనః"}},{"s":28,"p1":{"sa":"वृषाही वृषभो विष्णुः","ro":"Vṛṣāhī vṛṣabho viṣṇuḥ","te":"వృషాహీ వృషభో విష్ణుః"},"p2":{"sa":"वृषपर्वा वृषोदरः","ro":"vṛṣaparvā vṛṣodaraḥ","te":"వృషపర్వా వృషోదరః"},"p3":{"sa":"वर्धनो वर्धमानश्च","ro":"Vardhano vardhamānaśca","te":"వర్ధనో వర్ధమానశ్చ"},"p4":{"sa":"विविक्तः श्रुतिसागरः","ro":"viviktaḥ śrutisāgaraḥ","te":"వివిక్తః శ్రుతిసాగరః"}},{"s":29,"p1":{"sa":"सुभुजो दुर्धरो वाग्मी","ro":"Subhujo durdharo vāgmī","te":"సుభుజో దుర్ధరో వాగ్మీ"},"p2":{"sa":"महेन्द्रो वसुदो वसुः","ro":"mahendro vasudo vasuḥ","te":"మహేన్ద్రో వసుదో వసుః"},"p3":{"sa":"नैकरूपो बृहद्रूपः","ro":"Naikarūpo bṛhadrūpaḥ","te":"నైకరూపో బృహద్రూపః"},"p4":{"sa":"शिपिविष्टः प्रकाशनः","ro":"śipiviṣṭaḥ prakāśanaḥ","te":"శిపివిష్టః ప్రకాశనః"}},{"s":30,"p1":{"sa":"ओजस्तेजो द्युतिधरः","ro":"Ojastejo dyutidharaḥ","te":"ఓజస్తేజో ద్యుతిధరః"},"p2":{"sa":"प्रकाशात्मा प्रतापनः","ro":"prakāśātmā pratāpanaḥ","te":"ప్రకాశాత్మా ప్రతాపనః"},"p3":{"sa":"ऋद्धः स्पष्टाक्षरो मन्त्रः","ro":"Ṛddhaḥ spaṣṭākṣaro mantraḥ","te":"ఋద్ధః స్పష్టాక్షరో మన్త్రః"},"p4":{"sa":"चन्द्रांशुर्भास्करद्युतिः","ro":"candrāṃśurbhāskaradyutiḥ","te":"చన్ద్రాంశుర్భాస్కరద్యుతిః"}},{"s":31,"p1":{"sa":"अमृतांशूद्भवो भानुः","ro":"Amṛtāṃśūdbhavo bhānuḥ","te":"అమృతాంశూద్భవో భానుః"},"p2":{"sa":"शशबिन्दुः सुरेश्वरः","ro":"śaśabinduḥ sureśvaraḥ","te":"శశబిన్దుః సురేశ్వరః"},"p3":{"sa":"औषधं जगतः सेतुः","ro":"Auṣadhaṃ jagataḥ setuḥ","te":"ఔషధం జగతః సేతుః"},"p4":{"sa":"सत्यधर्मपराक्रमः","ro":"satyadharmaparākramaḥ","te":"సత్యధర్మపరాక్రమః"}},{"s":32,"p1":{"sa":"भूतभव्यभवन्नाथः","ro":"Bhūtabhavyabhavannāthaḥ","te":"భూతభవ్యభవన్నాథః"},"p2":{"sa":"पवनः पावनोऽनलः","ro":"pavanaḥ pāvano'nalaḥ","te":"పవనః పావనోఽనలః"},"p3":{"sa":"कामहा कामकृत्कान्तः","ro":"Kāmahā kāmakṛtkāntaḥ","te":"కామహా కామకృత్కాన్తః"},"p4":{"sa":"कामः कामप्रदः प्रभुः","ro":"kāmaḥ kāmapradaḥ prabhuḥ","te":"కామః కామప్రదః ప్రభుః"}},{"s":33,"p1":{"sa":"युगादिकृद्युगावर्तः","ro":"Yugādikṛdyugāvartaḥ","te":"యుగాదికృద్యుగావర్తః"},"p2":{"sa":"नैकमायो महाशनः","ro":"naikamāyo mahāśanaḥ","te":"నైకమాయో మహాశనః"},"p3":{"sa":"अदृश्यो व्यक्तरूपश्च","ro":"Adṛśyo vyaktarūpaśca","te":"అదృశ్యో వ్యక్తరూపశ్చ"},"p4":{"sa":"सहस्रजिदनन्तजित्","ro":"sahasrajidanantajit","te":"సహస్రజిదనన్తజిత్"}},{"s":34,"p1":{"sa":"इष्टोऽविशिष्टः शिष्टेष्टः","ro":"Iṣṭo'viśiṣṭaḥ śiṣṭeṣṭaḥ","te":"ఇష్టోఽవిశిష్టః శిష్టేష్టః"},"p2":{"sa":"शिखण्डी नहुषो वृषः","ro":"śikhaṇḍī nahuṣo vṛṣaḥ","te":"శిఖణ్డీ నహుషో వృషః"},"p3":{"sa":"क्रोधहा क्रोधकृत्कर्ता","ro":"Krodhahā krodhakṛtkartā","te":"క్రోధహా క్రోధకృత్కర్తా"},"p4":{"sa":"विश्वबाहुर्महीधरः","ro":"viśvabāhurmahīdharaḥ","te":"విశ్వబాహుర్మహీధరః"}},{"s":35,"p1":{"sa":"अच्युतः प्रथितः प्राणः","ro":"Acyutaḥ prathitaḥ prāṇaḥ","te":"అచ్యుతః ప్రథితః ప్రాణః"},"p2":{"sa":"प्राणदो वासवानुजः","ro":"prāṇado vāsavānujaḥ","te":"ప్రాణదో వాసవానుజః"},"p3":{"sa":"अपांनिधिरधिष्ठानम्","ro":"Apāṃnidhiradhiṣṭhānam","te":"అపాంనిధిరధిష్ఠానమ్"},"p4":{"sa":"अप्रमत्तः प्रतिष्ठितः","ro":"apramattaḥ pratiṣṭhitaḥ","te":"అప్రమత్తః ప్రతిష్ఠితః"}},{"s":36,"p1":{"sa":"स्कन्दः स्कन्दधरो धुर्यः","ro":"Skandaḥ skandadharo dhuryaḥ","te":"స్కన్దః స్కన్దధరో ధుర్యః"},"p2":{"sa":"वरदो वायुवाहनः","ro":"varado vāyuvāhanaḥ","te":"వరదో వాయువాహనః"},"p3":{"sa":"वासुदेवो बृहद्भानुः","ro":"Vāsudevo bṛhadbhānuḥ","te":"వాసుదేవో బృహద్భానుః"},"p4":{"sa":"आदिदेवः पुरन्दरः","ro":"ādidevaḥ purandaraḥ","te":"ఆదిదేవః పురన్దరః"}},{"s":37,"p1":{"sa":"अशोकस्तारणस्तारः","ro":"Aśokastāraṇastāraḥ","te":"అశోకస్తారణస్తారః"},"p2":{"sa":"शूरः शौरिर्जनेश्वरः","ro":"śūraḥ śaurirjaneśvaraḥ","te":"శూరః శౌరిర్జనేశ్వరః"},"p3":{"sa":"अनुकूलः शतावर्तः","ro":"Anukūlaḥ śatāvartaḥ","te":"అనుకూలః శతావర్తః"},"p4":{"sa":"पद्मी पद्मनिभेक्षणः","ro":"padmī padmanibhekṣaṇaḥ","te":"పద్మీ పద్మనిభేక్షణః"}},{"s":38,"p1":{"sa":"पद्मनाभोऽरविन्दाक्षः","ro":"Padmanābho'ravindākṣaḥ","te":"పద్మనాభోఽరవిన్దాక్షః"},"p2":{"sa":"पद्मगर्भः शरीरभृत्","ro":"padmagarbhaḥ śarīrabhṛt","te":"పద్మగర్భః శరీరభృత్"},"p3":{"sa":"महर्द्धिरृद्धो वृद्धात्मा","ro":"Maharddhirṛddho vṛddhātmā","te":"మహర్ద్ధిరృద్ధో వృద్ధాత్మా"},"p4":{"sa":"महाक्षो गरुडध्वजः","ro":"mahākṣo garuḍadhvajaḥ","te":"మహాక్షో గరుడధ్వజః"}},{"s":39,"p1":{"sa":"अतुलः शरभो भीमः","ro":"Atulaḥ śarabho bhīmaḥ","te":"అతులః శరభో భీమః"},"p2":{"sa":"समयज्ञो हविर्हरिः","ro":"samayajño havirhariḥ","te":"సమయజ్ఞో హవిర్హరిః"},"p3":{"sa":"सर्वलक्षणलक्षण्यः","ro":"Sarvalakṣaṇalakṣaṇyaḥ","te":"సర్వలక్షణలక్షణ్యః"},"p4":{"sa":"लक्ष्मीवान् समितिञ्जयः","ro":"lakṣmīvān samitiñjayaḥ","te":"లక్ష్మీవాన్ సమితిఞ్జయః"}},{"s":40,"p1":{"sa":"विक्षरो रोहितो मार्गः","ro":"Vikṣaro rohito mārgaḥ","te":"విక్షరో రోహితో మార్గః"},"p2":{"sa":"हेतुर्दामोदरः सहः","ro":"heturdāmodaraḥ sahaḥ","te":"హేతుర్దామోదరః సహః"},"p3":{"sa":"महीधरो महाभागः","ro":"Mahīdharo mahābhāgaḥ","te":"మహీధరో మహాభాగః"},"p4":{"sa":"वेगवानमिताशनः","ro":"vegavānamitāśanaḥ","te":"వేగవానమితాశనః"}},{"s":41,"p1":{"sa":"उद्भवः क्षोभणो देवः","ro":"Udbhavaḥ kṣobhaṇo devaḥ","te":"ఉద్భవః క్షోభణో దేవః"},"p2":{"sa":"श्रीगर्भः परमेश्वरः","ro":"śrīgarbhaḥ parameśvaraḥ","te":"శ్రీగర్భః పరమేశ్వరః"},"p3":{"sa":"करणं कारणं कर्ता","ro":"Karaṇaṃ kāraṇaṃ kartā","te":"కరణం కారణం కర్తా"},"p4":{"sa":"विकर्ता गहनो गुहः","ro":"vikartā gahano guhaḥ","te":"వికర్తా గహనో గుహః"}},{"s":42,"p1":{"sa":"व्यवसायो व्यवस्थानः","ro":"Vyavasāyo vyavasthānaḥ","te":"వ్యవసాయో వ్యవస్థానః"},"p2":{"sa":"संस्थानः स्थानदो ध्रुवः","ro":"saṃsthānaḥ sthānado dhruvaḥ","te":"సంస్థానః స్థానదో ధ్రువః"},"p3":{"sa":"परर्द्धिः परमस्पष्टः","ro":"Pararddhiḥ paramaspaṣṭaḥ","te":"పరర్ద్ధిః పరమస్పష్టః"},"p4":{"sa":"तुष्टः पुष्टः शुभेक्षणः","ro":"tuṣṭaḥ puṣṭaḥ śubhekṣaṇaḥ","te":"తుష్టః పుష్టః శుభేక్షణః"}},{"s":43,"p1":{"sa":"रामो विरामो विरजः","ro":"Rāmo virāmo virajaḥ","te":"రామో విరామో విరజః"},"p2":{"sa":"मार्गो नेयो नयोऽनयः","ro":"mārgo neyo nayo'nayaḥ","te":"మార్గో నేయో నయోఽనయః"},"p3":{"sa":"वीरः शक्तिमतां श्रेष्ठः","ro":"Vīraḥ śaktimatāṃ śreṣṭhaḥ","te":"వీరః శక్తిమతాం శ్రేష్ఠః"},"p4":{"sa":"धर्मो धर्मविदुत्तमः","ro":"dharmo dharmaviduttamaḥ","te":"ధర్మో ధర్మవిదుత్తమః"}},{"s":44,"p1":{"sa":"वैकुण्ठः पुरुषः प्राणः","ro":"Vaikuṇṭhaḥ puruṣaḥ prāṇaḥ","te":"వైకుణ్ఠః పురుషః ప్రాణః"},"p2":{"sa":"प्राणदः प्रणवः पृथुः","ro":"prāṇadaḥ praṇavaḥ pṛthuḥ","te":"ప్రాణదః ప్రణవః పృథుః"},"p3":{"sa":"हिरण्यगर्भः शत्रुघ्नः","ro":"Hiraṇyagarbhaḥ śatrughnaḥ","te":"హిరణ్యగర్భః శత్రుఘ్నః"},"p4":{"sa":"व्याप्तो वायुरधोक्षजः","ro":"vyāpto vāyuradhokṣajaḥ","te":"వ్యాప్తో వాయురధోక్షజః"}},{"s":45,"p1":{"sa":"ऋतुः सुदर्शनः कालः","ro":"Ṛtuḥ sudarśanaḥ kālaḥ","te":"ఋతుః సుదర్శనః కాలః"},"p2":{"sa":"परमेष्ठी परिग्रहः","ro":"parameṣṭhī parigrahaḥ","te":"పరమేష్ఠీ పరిగ్రహః"},"p3":{"sa":"उग्रः संवत्सरो दक्षः","ro":"Ugraḥ saṃvatsaro dakṣaḥ","te":"ఉగ్రః సంవత్సరో దక్షః"},"p4":{"sa":"विश्रामो विश्वदक्षिणः","ro":"viśrāmo viśvadakṣiṇaḥ","te":"విశ్రామో విశ్వదక్షిణః"}},{"s":46,"p1":{"sa":"विस्तारः स्थावरः स्थाणुः","ro":"Vistāraḥ sthāvaraḥ sthāṇuḥ","te":"విస్తారః స్థావరః స్థాణుః"},"p2":{"sa":"प्रमाणं बीजमव्ययम्","ro":"pramāṇaṃ bījamavyayam","te":"ప్రమాణం బీజమవ్యయమ్"},"p3":{"sa":"अर्थोऽनर्थो महाकोशः","ro":"Artho'nartho mahākośaḥ","te":"అర్థోఽనర్థో మహాకోశః"},"p4":{"sa":"महाभोगो महाधनः","ro":"mahābhogo mahādhanaḥ","te":"మహాభోగో మహాధనః"}},{"s":47,"p1":{"sa":"अनिर्विण्णः स्थविष्ठोऽभूः","ro":"Anirviṇṇaḥ sthaviṣṭho'bhūḥ","te":"అనిర్విణ్ణః స్థవిష్ఠోఽభూః"},"p2":{"sa":"धर्मयूपो महामखः","ro":"dharmayūpo mahāmakhaḥ","te":"ధర్మయూపో మహామఖః"},"p3":{"sa":"नक्षत्रनेमिर्नक्षत्री","ro":"Nakṣatranemirnakṣatrī","te":"నక్షత్రనేమిర్నక్షత్రీ"},"p4":{"sa":"क्षमः क्षामः समीहनः","ro":"kṣamaḥ kṣāmaḥ samīhanaḥ","te":"క్షమః క్షామః సమీహనః"}},{"s":48,"p1":{"sa":"यज्ञ इज्यो महेज्यश्च","ro":"Yajña ijyo mahejyaśca","te":"యజ్ఞ ఇజ్యో మహేజ్యశ్చ"},"p2":{"sa":"क्रतुः सत्रं सतां गतिः","ro":"kratuḥ satraṃ satāṃ gatiḥ","te":"క్రతుః సత్రం సతాం గతిః"},"p3":{"sa":"सर्वदर्शी विमुक्तात्मा","ro":"Sarvadarśī vimuktātmā","te":"సర్వదర్శీ విముక్తాత్మా"},"p4":{"sa":"सर्वज्ञो ज्ञानमुत्तमम्","ro":"sarvajño jñānamuttamam","te":"సర్వజ్ఞో జ్ఞానముత్తమమ్"}},{"s":49,"p1":{"sa":"सुव्रतः सुमुखः सूक्ष्मः","ro":"Suvrataḥ sumukhaḥ sūkṣmaḥ","te":"సువ్రతః సుముఖః సూక్ష్మః"},"p2":{"sa":"सुघोषः सुखदः सुहृत्","ro":"sughoṣaḥ sukhadaḥ suhṛt","te":"సుఘోషః సుఖదః సుహృత్"},"p3":{"sa":"मनोहरो जितक्रोधः","ro":"Manoharo jitakrodhaḥ","te":"మనోహరో జితక్రోధః"},"p4":{"sa":"वीरबाहुर्विदारणः","ro":"vīrabāhurvidāraṇaḥ","te":"వీరబాహుర్విదారణః"}},{"s":50,"p1":{"sa":"स्वापनः स्ववशो व्यापी","ro":"Svāpanaḥ svavaśo vyāpī","te":"స్వాపనః స్వవశో వ్యాపీ"},"p2":{"sa":"नैकात्मा नैककर्मकृत्","ro":"naikātmā naikakarmakṛt","te":"నైకాత్మా నైకకర్మకృత్"},"p3":{"sa":"वत्सरो वत्सलो वत्सी","ro":"Vatsaro vatsalo vatsī","te":"వత్సరో వత్సలో వత్సీ"},"p4":{"sa":"रत्नगर्भो धनेश्वरः","ro":"ratnagarbho dhaneśvaraḥ","te":"రత్నగర్భో ధనేశ్వరః"}},{"s":51,"p1":{"sa":"धर्मगुब्धर्मकृद्धर्मी","ro":"Dharmagubdharmakṛddharmī","te":"ధర్మగుబ్ధర్మకృద్ధర్మీ"},"p2":{"sa":"सदसत्क्षरमक्षरम्","ro":"sadasatkṣaramakṣaram","te":"సదసత్క్షరమక్షరమ్"},"p3":{"sa":"अविज्ञाता सहस्रांशुः","ro":"Avijñātā sahasrāṃśuḥ","te":"అవిజ్ఞాతా సహస్రాంశుః"},"p4":{"sa":"विधाता कृतलक्षणः","ro":"vidhātā kṛtalakṣaṇaḥ","te":"విధాతా కృతలక్షణః"}},{"s":52,"p1":{"sa":"गभस्तिनेमिः सत्त्वस्थः","ro":"Gabhastinemiḥ sattvasthaḥ","te":"గభస్తినేమిః సత్త్వస్థః"},"p2":{"sa":"सिंहो भूतमहेश्वरः","ro":"siṃho bhūtamaheśvaraḥ","te":"సింహో భూతమహేశ్వరః"},"p3":{"sa":"आदिदेवो महादेवः","ro":"Ādidevo mahādevaḥ","te":"ఆదిదేవో మహాదేవః"},"p4":{"sa":"देवेशो देवभृद्गुरुः","ro":"deveśo devabhṛdguruḥ","te":"దేవేశో దేవభృద్గురుః"}},{"s":53,"p1":{"sa":"उत्तरो गोपतिर्गोप्ता","ro":"Uttaro gopatirgoptā","te":"ఉత్తరో గోపతిర్గోప్తా"},"p2":{"sa":"ज्ञानगम्यः पुरातनः","ro":"jñānagamyaḥ purātanaḥ","te":"జ్ఞానగమ్యః పురాతనః"},"p3":{"sa":"शरीरभूतभृद्भोक्ता","ro":"Śarīrabhūtabhṛdbhoktā","te":"శరీరభూతభృద్భోక్తా"},"p4":{"sa":"कपीन्द्रो भूरिदक्षिणः","ro":"kapīndro bhūridakṣiṇaḥ","te":"కపీన్ద్రో భూరిదక్షిణః"}},{"s":54,"p1":{"sa":"सोमपोऽमृतपः सोमः","ro":"Somapo'mṛtapaḥ somaḥ","te":"సోమపోఽమృతపః సోమః"},"p2":{"sa":"पुरुजित्पुरुसत्तमः","ro":"purujitpurusattamaḥ","te":"పురుజిత్పురుసత్తమః"},"p3":{"sa":"विनयो जयः सत्यसन्धः","ro":"Vinayo jayaḥ satyasandhaḥ","te":"వినయో జయః సత్యసన్ధః"},"p4":{"sa":"दाशार्हः सात्वताम्पतिः","ro":"dāśārhaḥ sātvatāmpatiḥ","te":"దాశార్హః సాత్వతామ్పతిః"}},{"s":55,"p1":{"sa":"जीवो विनयिता साक्षी","ro":"Jīvo vinayitā sākṣī","te":"జీవో వినయితా సాక్షీ"},"p2":{"sa":"मुकुन्दोऽमितविक्रमः","ro":"mukundo'mitavikramaḥ","te":"ముకున్దోఽమితవిక్రమః"},"p3":{"sa":"अम्भोनिधिरनन्तात्मा","ro":"Ambhonidhiranantātmā","te":"అమ్భోనిధిరనన్తాత్మా"},"p4":{"sa":"महोदधिशयोऽन्तकः","ro":"mahodadhiśayo'ntakaḥ","te":"మహోదధిశయోఽన్తకః"}},{"s":56,"p1":{"sa":"अजो महार्हः स्वाभाव्यः","ro":"Ajo mahārhaḥ svābhāvyaḥ","te":"అజో మహార్హః స్వాభావ్యః"},"p2":{"sa":"जितामित्रः प्रमोदनः","ro":"jitāmitraḥ pramodanaḥ","te":"జితామిత్రః ప్రమోదనః"},"p3":{"sa":"आनन्दो नन्दनो नन्दः","ro":"Ānando nandano nandaḥ","te":"ఆనన్దో నన్దనో నన్దః"},"p4":{"sa":"सत्यधर्मा त्रिविक्रमः","ro":"satyadharmā trivikramaḥ","te":"సత్యధర్మా త్రివిక్రమః"}},{"s":57,"p1":{"sa":"महर्षिः कपिलाचार्यः","ro":"Maharṣiḥ kapilācāryaḥ","te":"మహర్షిః కపిలాచార్యః"},"p2":{"sa":"कृतज्ञो मेदिनीपतिः","ro":"kṛtajño medinīpatiḥ","te":"కృతజ్ఞో మేదినీపతిః"},"p3":{"sa":"त्रिपदस्त्रिदशाध्यक्षः","ro":"Tripadastridaśādhyakṣaḥ","te":"త్రిపదస్త్రిదశాధ్యక్షః"},"p4":{"sa":"महाशृङ्गः कृतान्तकृत्","ro":"mahāśṛṅgaḥ kṛtāntakṛt","te":"మహాశృఙ్గః కృతాన్తకృత్"}},{"s":58,"p1":{"sa":"महावराहो गोविन्दः","ro":"Mahāvarāho govindaḥ","te":"మహావరాహో గోవిన్దః"},"p2":{"sa":"सुषेणः कनकाङ्गदी","ro":"suṣeṇaḥ kanakāṅgadī","te":"సుషేణః కనకాఙ్గదీ"},"p3":{"sa":"गुह्यो गभीरो गहनः","ro":"Guhyo gabhīro gahanaḥ","te":"గుహ్యో గభీరో గహనః"},"p4":{"sa":"गुप्तश्चक्रगदाधरः","ro":"guptaścakragadādharaḥ","te":"గుప్తశ్చక్రగదాధరః"}},{"s":59,"p1":{"sa":"वेधाः स्वाङ्गोऽजितः कृष्णः","ro":"Vedhāḥ svāṅgo'jitaḥ kṛṣṇaḥ","te":"వేధాః స్వాఙ్గోఽజితః కృష్ణః"},"p2":{"sa":"दृढः सङ्कर्षणोऽच्युतः","ro":"dṛḍhaḥ saṅkarṣaṇo'cyutaḥ","te":"దృఢః సఙ్కర్షణోఽచ్యుతః"},"p3":{"sa":"वरुणो वारुणो वृक्षः","ro":"Varuṇo vāruṇo vṛkṣaḥ","te":"వరుణో వారుణో వృక్షః"},"p4":{"sa":"पुष्कराक्षो महामनाः","ro":"puṣkarākṣo mahāmanāḥ","te":"పుష్కరాక్షో మహామనాః"}},{"s":60,"p1":{"sa":"भगवान् भगहाऽऽनन्दी","ro":"Bhagavān bhagahā''nandī","te":"భగవాన్ భగహాఽఽనన్దీ"},"p2":{"sa":"वनमाली हलायुधः","ro":"vanamālī halāyudhaḥ","te":"వనమాలీ హలాయుధః"},"p3":{"sa":"आदित्यो ज्योतिरादित्यः","ro":"Ādityo jyotirādityaḥ","te":"ఆదిత్యో జ్యోతిరాదిత్యః"},"p4":{"sa":"सहिष्णुर्गतिसत्तमः","ro":"sahiṣṇurgatisattamaḥ","te":"సహిష్ణుర్గతిసత్తమః"}},{"s":61,"p1":{"sa":"सुधन्वा खण्डपरशुः","ro":"Sudhanvā khaṇḍaparaśuḥ","te":"సుధన్వా ఖణ్డపరశుః"},"p2":{"sa":"दारुणो द्रविणप्रदः","ro":"dāruṇo draviṇapradaḥ","te":"దారుణో ద్రవిణప్రదః"},"p3":{"sa":"दिवस्पृक् सर्वदृग्व्यासः","ro":"Divaspṛk sarvadṛgvyāsaḥ","te":"దివస్పృక్ సర్వదృగ్వ్యాసః"},"p4":{"sa":"वाचस्पतिरयोनिजः","ro":"vācaspatirayonijaḥ","te":"వాచస్పతిరయోనిజః"}},{"s":62,"p1":{"sa":"त्रिसामा सामगः साम","ro":"Trisāmā sāmagaḥ sāma","te":"త్రిసామా సామగః సామ"},"p2":{"sa":"निर्वाणं भेषजं भिषक्","ro":"nirvāṇaṃ bheṣajaṃ bhiṣak","te":"నిర్వాణం భేషజం భిషక్"},"p3":{"sa":"संन्यासकृच्छमः शान्तः","ro":"Saṃnyāsakṛcchamaḥ śāntaḥ","te":"సంన్యాసకృచ్ఛమః శాన్తః"},"p4":{"sa":"निष्ठा शान्तिः परायणम्","ro":"niṣṭhā śāntiḥ parāyaṇam","te":"నిష్ఠా శాన్తిః పరాయణమ్"}},{"s":63,"p1":{"sa":"शुभाङ्गः शान्तिदः स्रष्टा","ro":"Śubhāṅgaḥ śāntidaḥ sraṣṭā","te":"శుభాఙ్గః శాన్తిదః స్రష్టా"},"p2":{"sa":"कुमुदः कुवलेशयः","ro":"kumudaḥ kuvaleśayaḥ","te":"కుముదః కువలేశయః"},"p3":{"sa":"गोहितो गोपतिर्गोप्ता","ro":"Gohito gopatirgoptā","te":"గోహితో గోపతిర్గోప్తా"},"p4":{"sa":"वृषभाक्षो वृषप्रियः","ro":"vṛṣabhākṣo vṛṣapriyaḥ","te":"వృషభాక్షో వృషప్రియః"}},{"s":64,"p1":{"sa":"अनिवर्ती निवृत्तात्मा","ro":"Anivartī nivṛttātmā","te":"అనివర్తీ నివృత్తాత్మా"},"p2":{"sa":"सङ्क्षेप्ता क्षेमकृच्छिवः","ro":"saṅkṣeptā kṣemakṛcchivaḥ","te":"సఙ్క్షేప్తా క్షేమకృచ్ఛివః"},"p3":{"sa":"श्रीवत्सवक्षाः श्रीवासः","ro":"Śrīvatsavakṣāḥ śrīvāsaḥ","te":"శ్రీవత్సవక్షాః శ్రీవాసః"},"p4":{"sa":"श्रीपतिः श्रीमतांवरः","ro":"śrīpatiḥ śrīmatāṃvaraḥ","te":"శ్రీపతిః శ్రీమతాంవరః"}},{"s":65,"p1":{"sa":"श्रीदः श्रीशः श्रीनिवासः","ro":"Śrīdaḥ śrīśaḥ śrīnivāsaḥ","te":"శ్రీదః శ్రీశః శ్రీనివాసః"},"p2":{"sa":"श्रीनिधिः श्रीविभावनः","ro":"śrīnidhiḥ śrīvibhāvanaḥ","te":"శ్రీనిధిః శ్రీవిభావనః"},"p3":{"sa":"श्रीधरः श्रीकरः श्रेयः","ro":"Śrīdharaḥ śrīkaraḥ śreyaḥ","te":"శ్రీధరః శ్రీకరః శ్రేయః"},"p4":{"sa":"श्रीमाल्लोकत्रयाश्रयः","ro":"śrīmāllokatrayāśrayaḥ","te":"శ్రీమాల్లోకత్రయాశ్రయః"}},{"s":66,"p1":{"sa":"स्वक्षः स्वङ्गः शतानन्दः","ro":"Svakṣaḥ svaṅgaḥ śatānandaḥ","te":"స్వక్షః స్వఙ్గః శతానన్దః"},"p2":{"sa":"नन्दिर्ज्योतिर्गणेश्वरः","ro":"nandirjyotirgaṇeśvaraḥ","te":"నన్దిర్జ్యోతిర్గణేశ్వరః"},"p3":{"sa":"विजितात्माविधेयात्मा","ro":"Vijitātmāvidheyātmā","te":"విజితాత్మావిధేయాత్మా"},"p4":{"sa":"सत्कीर्तिश्छिन्नसंशयः","ro":"satkīrtiśchinnasaṃśayaḥ","te":"సత్కీర్తిశ్ఛిన్నసంశయః"}},{"s":67,"p1":{"sa":"उदीर्णः सर्वतश्चक्षुः","ro":"Udīrṇaḥ sarvataścakṣuḥ","te":"ఉదీర్ణః సర్వతశ్చక్షుః"},"p2":{"sa":"अनीशः शाश्वतस्थिरः","ro":"anīśaḥ śāśvatasthiraḥ","te":"అనీశః శాశ్వతస్థిరః"},"p3":{"sa":"भूशयो भूषणो भूतिः","ro":"Bhūśayo bhūṣaṇo bhūtiḥ","te":"భూశయో భూషణో భూతిః"},"p4":{"sa":"विशोकः शोकनाशनः","ro":"viśokaḥ śokanāśanaḥ","te":"విశోకః శోకనాశనః"}},{"s":68,"p1":{"sa":"अर्चिष्मानर्चितः कुम्भः","ro":"Arciṣmānarcitaḥ kumbhaḥ","te":"అర్చిష్మానర్చితః కుమ్భః"},"p2":{"sa":"विशुद्धात्मा विशोधनः","ro":"viśuddhātmā viśodhanaḥ","te":"విశుద్ధాత్మా విశోధనః"},"p3":{"sa":"अनिरुद्धोऽप्रतिरथः","ro":"Aniruddho'pratirathaḥ","te":"అనిరుద్ధోఽప్రతిరథః"},"p4":{"sa":"प्रद्युम्नोऽमितविक्रमः","ro":"pradyumno'mitavikramaḥ","te":"ప్రద్యుమ్నోఽమితవిక్రమః"}},{"s":69,"p1":{"sa":"कालनेमिनिहा वीरः","ro":"Kālaneminihā vīraḥ","te":"కాలనేమినిహా వీరః"},"p2":{"sa":"शौरिः शूरजनेश्वरः","ro":"śauriḥ śūrajaneśvaraḥ","te":"శౌరిః శూరజనేశ్వరః"},"p3":{"sa":"त्रिलोकात्मा त्रिलोकेशः","ro":"Trilokātmā trilokeśaḥ","te":"త్రిలోకాత్మా త్రిలోకేశః"},"p4":{"sa":"केशवः केशिहा हरिः","ro":"keśavaḥ keśihā hariḥ","te":"కేశవః కేశిహా హరిః"}},{"s":70,"p1":{"sa":"कामदेवः कामपालः","ro":"Kāmadevaḥ kāmapālaḥ","te":"కామదేవః కామపాలః"},"p2":{"sa":"कामी कान्तः कृतागमः","ro":"kāmī kāntaḥ kṛtāgamaḥ","te":"కామీ కాన్తః కృతాగమః"},"p3":{"sa":"अनिर्देश्यवपुर्विष्णुः","ro":"Anirdeśyavapurviṣṇuḥ","te":"అనిర్దేశ్యవపుర్విష్ణుః"},"p4":{"sa":"वीरोऽनन्तो धनञ्जयः","ro":"vīro'nanto dhanañjayaḥ","te":"వీరోఽనన్తో ధనఞ్జయః"}},{"s":71,"p1":{"sa":"ब्रह्मण्यो ब्रह्मकृद् ब्रह्मा","ro":"Brahmaṇyo brahmakṛd brahmā","te":"బ్రహ్మణ్యో బ్రహ్మకృద్ బ్రహ్మా"},"p2":{"sa":"ब्रह्म ब्रह्मविवर्धनः","ro":"brahma brahmavivardhanaḥ","te":"బ్రహ్మ బ్రహ్మవివర్ధనః"},"p3":{"sa":"ब्रह्मविद् ब्राह्मणो ब्रह्मी","ro":"Brahmavid brāhmaṇo brahmī","te":"బ్రహ్మవిద్ బ్రాహ్మణో బ్రహ్మీ"},"p4":{"sa":"ब्रह्मज्ञो ब्राह्मणप्रियः","ro":"brahmajño brāhmaṇapriyaḥ","te":"బ్రహ్మజ్ఞో బ్రాహ్మణప్రియః"}},{"s":72,"p1":{"sa":"महाक्रमो महाकर्मा","ro":"Mahākramo mahākarmā","te":"మహాక్రమో మహాకర్మా"},"p2":{"sa":"महातेजा महोरगः","ro":"mahātejā mahoragaḥ","te":"మహాతేజా మహోరగః"},"p3":{"sa":"महाक्रतुर्महायज्वा","ro":"Mahākraturmahāyajvā","te":"మహాక్రతుర్మహాయజ్వా"},"p4":{"sa":"महायज्ञो महाहविः","ro":"mahāyajño mahāhaviḥ","te":"మహాయజ్ఞో మహాహవిః"}},{"s":73,"p1":{"sa":"स्तव्यः स्तवप्रियः स्तोत्रं","ro":"Stavyaḥ stavapriyaḥ stotraṃ","te":"స్తవ్యః స్తవప్రియః స్తోత్రం"},"p2":{"sa":"स्तुतिः स्तोता रणप्रियः","ro":"stutiḥ stotā raṇapriyaḥ","te":"స్తుతిః స్తోతా రణప్రియః"},"p3":{"sa":"पूर्णः पूरयिता पुण्यः","ro":"Pūrṇaḥ pūrayitā puṇyaḥ","te":"పూర్ణః పూరయితా పుణ్యః"},"p4":{"sa":"पुण्यकीर्तिरनामयः","ro":"puṇyakīrtiranāmayaḥ","te":"పుణ్యకీర్తిరనామయః"}},{"s":74,"p1":{"sa":"मनोजवस्तीर्थकरः","ro":"Manojavastīrthakaraḥ","te":"మనోజవస్తీర్థకరః"},"p2":{"sa":"वसुरेता वसुप्रदः","ro":"vasuretā vasupradaḥ","te":"వసురేతా వసుప్రదః"},"p3":{"sa":"वसुप्रदो वासुदेवः","ro":"Vasuprado vāsudevaḥ","te":"వసుప్రదో వాసుదేవః"},"p4":{"sa":"वसुर्वसुमना हविः","ro":"vasurvasumanā haviḥ","te":"వసుర్వసుమనా హవిః"}},{"s":75,"p1":{"sa":"सद्गतिः सत्कृतिः सत्ता","ro":"Sadgatiḥ satkṛtiḥ sattā","te":"సద్గతిః సత్కృతిః సత్తా"},"p2":{"sa":"सद्भूतिः सत्परायणः","ro":"sadbhūtiḥ satparāyaṇaḥ","te":"సద్భూతిః సత్పరాయణః"},"p3":{"sa":"शूरसेनो यदुश्रेष्ठः","ro":"Śūraseno yaduśreṣṭhaḥ","te":"శూరసేనో యదుశ్రేష్ఠః"},"p4":{"sa":"सन्निवासः सुयामुनः","ro":"sannivāsaḥ suyāmunaḥ","te":"సన్నివాసః సుయామునః"}},{"s":76,"p1":{"sa":"भूतावासो वासुदेवः","ro":"Bhūtāvāso vāsudevaḥ","te":"భూతావాసో వాసుదేవః"},"p2":{"sa":"सर्वासुनिलयोऽनलः","ro":"sarvāsunilayo'nalaḥ","te":"సర్వాసునిలయోఽనలః"},"p3":{"sa":"दर्पहा दर्पदो दृप्तः","ro":"Darpahā darpado dṛptaḥ","te":"దర్పహా దర్పదో దృప్తః"},"p4":{"sa":"दुर्धरोऽथापराजितः","ro":"durdharo'thāparājitaḥ","te":"దుర్ధరోఽథాపరాజితః"}},{"s":77,"p1":{"sa":"विश्वमूर्तिर्महामूर्तिः","ro":"Viśvamūrtirmahāmūrtiḥ","te":"విశ్వమూర్తిర్మహామూర్తిః"},"p2":{"sa":"दीप्तमूर्तिरमूर्तिमान्","ro":"dīptamūrtiramūrtimān","te":"దీప్తమూర్తిరమూర్తిమాన్"},"p3":{"sa":"अनेकमूर्तिरव्यक्तः","ro":"Anekamūrtiravyaktaḥ","te":"అనేకమూర్తిరవ్యక్తః"},"p4":{"sa":"शतमूर्तिः शताननः","ro":"śatamūrtiḥ śatānanaḥ","te":"శతమూర్తిః శతాననః"}},{"s":78,"p1":{"sa":"एको नैकः सवः कः किं","ro":"Eko naikaḥ savaḥ kaḥ kiṃ","te":"ఏకో నైకః సవః కః కిం"},"p2":{"sa":"यत् तत्पदमनुत्तमम्","ro":"yat tatpadamanuttamam","te":"యత్ తత్పదమనుత్తమమ్"},"p3":{"sa":"लोकबन्धुर्लोकनाथः","ro":"Lokabandhurlokanāthaḥ","te":"లోకబన్ధుర్లోకనాథః"},"p4":{"sa":"माधवो भक्तवत्सलः","ro":"mādhavo bhaktavatsalaḥ","te":"మాధవో భక్తవత్సలః"}},{"s":79,"p1":{"sa":"सुवर्णवर्णो हेमाङ्गः","ro":"Suvarṇavarṇo hemāṅgaḥ","te":"సువర్ణవర్ణో హేమాఙ్గః"},"p2":{"sa":"वराङ्गश्चन्दनाङ्गदी","ro":"varāṅgaścandanāṅgadī","te":"వరాఙ్గశ్చన్దనాఙ్గదీ"},"p3":{"sa":"वीरहा विषमः शून्यः","ro":"Vīrahā viṣamaḥ śūnyaḥ","te":"వీరహా విషమః శూన్యః"},"p4":{"sa":"घृताशीरचलश्चलः","ro":"ghṛtāśīracalaścalaḥ","te":"ఘృతాశీరచలశ్చలః"}},{"s":80,"p1":{"sa":"अमानी मानदो मान्यः","ro":"Amānī mānado mānyaḥ","te":"అమానీ మానదో మాన్యః"},"p2":{"sa":"लोकस्वामी त्रिलोकधृक्","ro":"lokasvāmī trilokadhṛk","te":"లోకస్వామీ త్రిలోకధృక్"},"p3":{"sa":"सुमेधा मेधजो धन्यः","ro":"Sumedhā medhajo dhanyaḥ","te":"సుమేధా మేధజో ధన్యః"},"p4":{"sa":"सत्यमेधा धराधरः","ro":"satyamedhā dharādharaḥ","te":"సత్యమేధా ధరాధరః"}},{"s":81,"p1":{"sa":"तेजोवृषो द्युतिधरः","ro":"Tejovṛṣo dyutidharaḥ","te":"తేజోవృషో ద్యుతిధరః"},"p2":{"sa":"सर्वशस्त्रभृतां वरः","ro":"sarvaśastrabhṛtāṃ varaḥ","te":"సర్వశస్త్రభృతాం వరః"},"p3":{"sa":"प्रग्रहो निग्रहो व्यग्रः","ro":"Pragraho nigraho vyagraḥ","te":"ప్రగ్రహో నిగ్రహో వ్యగ్రః"},"p4":{"sa":"नैकशृङ्गो गदाग्रजः","ro":"naikaśṛṅgo gadāgrajaḥ","te":"నైకశృఙ్గో గదాగ్రజః"}},{"s":82,"p1":{"sa":"चतुर्मूर्तिश्चतुर्बाहुः","ro":"Caturmūrtiścaturbāhuḥ","te":"చతుర్మూర్తిశ్చతుర్బాహుః"},"p2":{"sa":"चतुर्व्यूहश्चतुर्गतिः","ro":"caturvyūhaścaturgatiḥ","te":"చతుర్వ్యూహశ్చతుర్గతిః"},"p3":{"sa":"चतुरात्मा चतुर्भावः","ro":"Caturātmā caturbhāvaḥ","te":"చతురాత్మా చతుర్భావః"},"p4":{"sa":"चतुर्वेदविदेकपात्","ro":"caturvedavidekapāt","te":"చతుర్వేదవిదేకపాత్"}},{"s":83,"p1":{"sa":"समावर्तोऽनिवृत्तात्मा","ro":"Samāvarto'nivṛttātmā","te":"సమావర్తోఽనివృత్తాత్మా"},"p2":{"sa":"दुर्जयो दुरतिक्रमः","ro":"durjayo duratikramaḥ","te":"దుర్జయో దురతిక్రమః"},"p3":{"sa":"दुर्लभो दुर्गमो दुर्गः","ro":"Durlabho durgamo durgaḥ","te":"దుర్లభో దుర్గమో దుర్గః"},"p4":{"sa":"दुरावासो दुरारिहा","ro":"durāvāso durārihā","te":"దురావాసో దురారిహా"}},{"s":84,"p1":{"sa":"शुभाङ्गो लोकसारङ्गः","ro":"Śubhāṅgo lokasāraṅgaḥ","te":"శుభాఙ్గో లోకసారఙ్గః"},"p2":{"sa":"सुतन्तुस्तन्तुवर्धनः","ro":"sutantustantuvardhanaḥ","te":"సుతన్తుస్తన్తువర్ధనః"},"p3":{"sa":"इन्द्रकर्मा महाकर्मा","ro":"Indrakarmā mahākarmā","te":"ఇన్ద్రకర్మా మహాకర్మా"},"p4":{"sa":"कृतकर्मा कृतागमः","ro":"kṛtakarmā kṛtāgamaḥ","te":"కృతకర్మా కృతాగమః"}},{"s":85,"p1":{"sa":"उद्भवः सुन्दरः सुन्दः","ro":"Udbhavaḥ sundaraḥ sundaḥ","te":"ఉద్భవః సున్దరః సున్దః"},"p2":{"sa":"रत्ननाभः सुलोचनः","ro":"ratnanābhaḥ sulocanaḥ","te":"రత్ననాభః సులోచనః"},"p3":{"sa":"अर्को वाजसनः शृङ्गी","ro":"Arko vājasanaḥ śṛṅgī","te":"అర్కో వాజసనః శృఙ్గీ"},"p4":{"sa":"जयन्तः सर्वविज्जयी","ro":"jayantaḥ sarvavijjayī","te":"జయన్తః సర్వవిజ్జయీ"}},{"s":86,"p1":{"sa":"सुवर्णबिन्दुरक्षोभ्यः","ro":"Suvarṇabindurakṣobhyaḥ","te":"సువర్ణబిన్దురక్షోభ్యః"},"p2":{"sa":"सर्ववागीश्वरेश्वरः","ro":"sarvavāgīśvareśvaraḥ","te":"సర్వవాగీశ్వరేశ్వరః"},"p3":{"sa":"महाह्रदो महागर्तः","ro":"Mahāhrado mahāgartaḥ","te":"మహాహ్రదో మహాగర్తః"},"p4":{"sa":"महाभूतो महानिधिः","ro":"mahābhūto mahānidhiḥ","te":"మహాభూతో మహానిధిః"}},{"s":87,"p1":{"sa":"महाह्रदो महागर्तः","ro":"Mahāhrado mahāgartaḥ","te":"మహాహ్రదో మహాగర్తః"},"p2":{"sa":"महाभूतो महानिधिः ॥८६॥","ro":"mahābhūto mahānidhiḥ ||86","te":"మహాభూతో మహానిధిః ॥౮౬॥"},"p3":{"sa":"कुमुदः कुन्दरः कुन्दः","ro":"Kumudaḥ kundaraḥ kundaḥ","te":"కుముదః కున్దరః కున్దః"},"p4":{"sa":"पर्जन्यः पावनोऽनिलः ।अमृतांशोऽमृतवपुः सर्वज्ञः सर्वतोमुखः","ro":"parjanyaḥ pāvano'nilaḥ |amṛtāṃśo'mṛtavapuḥ sarvajñaḥ sarvatomukhaḥ","te":"పర్జన్యః పావనోఽనిలః ।అమృతాంశోఽమృతవపుః సర్వజ్ఞః సర్వతోముఖః"}},{"s":88,"p1":{"sa":"सुलभः सुव्रतः सिद्धः","ro":"Sulabhaḥ suvrataḥ siddhaḥ","te":"సులభః సువ్రతః సిద్ధః"},"p2":{"sa":"शत्रुजिच्छत्रुतापनः","ro":"śatrujicchatrutāpanaḥ","te":"శత్రుజిచ్ఛత్రుతాపనః"},"p3":{"sa":"न्यग्रोधोऽदुम्बरोऽश्वत्थः","ro":"Nyagrodho'dumbaro'śvatthaḥ","te":"న్యగ్రోధోఽదుమ్బరోఽశ్వత్థః"},"p4":{"sa":"चाणूरान्ध्रनिषूदनः","ro":"cāṇūrāndhraniṣūdanaḥ","te":"చాణూరాన్ధ్రనిషూదనః"}},{"s":89,"p1":{"sa":"सहस्रार्चिः सप्तजिह्वः","ro":"Sahasrārciḥ saptajihvaḥ","te":"సహస్రార్చిః సప్తజిహ్వః"},"p2":{"sa":"सप्तैधाः सप्तवाहनः","ro":"saptaidhāḥ saptavāhanaḥ","te":"సప్తైధాః సప్తవాహనః"},"p3":{"sa":"अमूर्तिरनघोऽचिन्त्यः","ro":"Amūrtiranagho'cintyaḥ","te":"అమూర్తిరనఘోఽచిన్త్యః"},"p4":{"sa":"भयकृद्भयनाशनः","ro":"bhayakṛdbhayanāśanaḥ","te":"భయకృద్భయనాశనః"}},{"s":90,"p1":{"sa":"अणुर्बृहत्कृशः स्थूलः","ro":"Aṇurbṛhatkṛśaḥ sthūlaḥ","te":"అణుర్బృహత్కృశః స్థూలః"},"p2":{"sa":"गुणभृन्निर्गुणो महान्","ro":"guṇabhṛnnirguṇo mahān","te":"గుణభృన్నిర్గుణో మహాన్"},"p3":{"sa":"अधृतः स्वधृतः स्वास्यः","ro":"Adhṛtaḥ svadhṛtaḥ svāsyaḥ","te":"అధృతః స్వధృతః స్వాస్యః"},"p4":{"sa":"प्राग्वंशो वंशवर्धनः","ro":"prāgvaṃśo vaṃśavardhanaḥ","te":"ప్రాగ్వంశో వంశవర్ధనః"}},{"s":91,"p1":{"sa":"भारभृत् कथितो योगी","ro":"Bhārabhṛt kathito yogī","te":"భారభృత్ కథితో యోగీ"},"p2":{"sa":"योगीशः सर्वकामदः","ro":"yogīśaḥ sarvakāmadaḥ","te":"యోగీశః సర్వకామదః"},"p3":{"sa":"आश्रमः श्रमणः क्षामः","ro":"Āśramaḥ śramaṇaḥ kṣāmaḥ","te":"ఆశ్రమః శ్రమణః క్షామః"},"p4":{"sa":"सुपर्णो वायुवाहनः","ro":"suparṇo vāyuvāhanaḥ","te":"సుపర్ణో వాయువాహనః"}},{"s":92,"p1":{"sa":"धनुर्धरो धनुर्वेदः","ro":"Dhanurdharo dhanurvedaḥ","te":"ధనుర్ధరో ధనుర్వేదః"},"p2":{"sa":"दण्डो दमयिता दमः","ro":"daṇḍo damayitā damaḥ","te":"దణ్డో దమయితా దమః"},"p3":{"sa":"अपराजितः सर्वसहः","ro":"Aparājitaḥ sarvasahaḥ","te":"అపరాజితః సర్వసహః"},"p4":{"sa":"नियन्तानियमोऽयमः","ro":"niyantāniyamo'yamaḥ","te":"నియన్తానియమోఽయమః"}},{"s":93,"p1":{"sa":"सत्त्ववान् सात्त्विकः सत्यः","ro":"Sattvavān sāttvikaḥ satyaḥ","te":"సత్త్వవాన్ సాత్త్వికః సత్యః"},"p2":{"sa":"सत्यधर्मपरायणः","ro":"satyadharmaparāyaṇaḥ","te":"సత్యధర్మపరాయణః"},"p3":{"sa":"अभिप्रायः प्रियार्होऽर्हः","ro":"Abhiprāyaḥ priyārho'rhaḥ","te":"అభిప్రాయః ప్రియార్హోఽర్హః"},"p4":{"sa":"प्रियकृत् प्रीतिवर्धनः","ro":"priyakṛt prītivardhanaḥ","te":"ప్రియకృత్ ప్రీతివర్ధనః"}},{"s":94,"p1":{"sa":"विहायसगतिर्ज्योतिः","ro":"Vihāyasagatirjyotiḥ","te":"విహాయసగతిర్జ్యోతిః"},"p2":{"sa":"सुरुचिर्हुतभुग्विभुः","ro":"surucirhutabhugvibhuḥ","te":"సురుచిర్హుతభుగ్విభుః"},"p3":{"sa":"रविर्विरोचनः सूर्यः","ro":"Ravirvirocanaḥ sūryaḥ","te":"రవిర్విరోచనః సూర్యః"},"p4":{"sa":"सविता रविलोचनः","ro":"savitā ravilocanaḥ","te":"సవితా రవిలోచనః"}},{"s":95,"p1":{"sa":"अनन्तो हुतभुग्भोक्ता","ro":"Ananto hutabhugbhoktā","te":"అనన్తో హుతభుగ్భోక్తా"},"p2":{"sa":"सुखदो नैकजोऽग्रजः","ro":"sukhado naikajo'grajaḥ","te":"సుఖదో నైకజోఽగ్రజః"},"p3":{"sa":"अनिर्विण्णः सदामर्षी","ro":"Anirviṇṇaḥ sadāmarṣī","te":"అనిర్విణ్ణః సదామర్షీ"},"p4":{"sa":"लोकाधिष्ठानमद्भुतः","ro":"lokādhiṣṭhānamadbhutaḥ","te":"లోకాధిష్ఠానమద్భుతః"}},{"s":96,"p1":{"sa":"सनात्सनातनतमः","ro":"Sanātsanātanatamaḥ","te":"సనాత్సనాతనతమః"},"p2":{"sa":"कपिलः कपिरव्ययः","ro":"kapilaḥ kapiravyayaḥ","te":"కపిలః కపిరవ్యయః"},"p3":{"sa":"स्वस्तिदः स्वस्तिकृत्स्वस्ति","ro":"Svastidaḥ svastikṛtsvasti","te":"స్వస్తిదః స్వస్తికృత్స్వస్తి"},"p4":{"sa":"स्वस्तिभुक्स्वस्तिदक्षिणः","ro":"svastibhuksvastidakṣiṇaḥ","te":"స్వస్తిభుక్స్వస్తిదక్షిణః"}},{"s":97,"p1":{"sa":"अरौद्रः कुण्डली चक्री","ro":"Araudraḥ kuṇḍalī cakrī","te":"అరౌద్రః కుణ్డలీ చక్రీ"},"p2":{"sa":"विक्रम्यूर्जितशासनः","ro":"vikramyūrjitaśāsanaḥ","te":"విక్రమ్యూర్జితశాసనః"},"p3":{"sa":"शब्दातिगः शब्दसहः","ro":"Śabdātigaḥ śabdasahaḥ","te":"శబ్దాతిగః శబ్దసహః"},"p4":{"sa":"शिशिरः शर्वरीकरः","ro":"śiśiraḥ śarvarīkaraḥ","te":"శిశిరః శర్వరీకరః"}},{"s":98,"p1":{"sa":"अक्रूरः पेशलो दक्षः","ro":"Akrūraḥ peśalo dakṣaḥ","te":"అక్రూరః పేశలో దక్షః"},"p2":{"sa":"दक्षिणः क्षमिणां वरः","ro":"dakṣiṇaḥ kṣamiṇāṃ varaḥ","te":"దక్షిణః క్షమిణాం వరః"},"p3":{"sa":"विद्वत्तमो वीतभयः","ro":"Vidvattamo vītabhayaḥ","te":"విద్వత్తమో వీతభయః"},"p4":{"sa":"पुण्यश्रवणकीर्तनः","ro":"puṇyaśravaṇakīrtanaḥ","te":"పుణ్యశ్రవణకీర్తనః"}},{"s":99,"p1":{"sa":"उत्तारणो दुष्कृतिहा","ro":"Uttāraṇo duṣkṛtihā","te":"ఉత్తారణో దుష్కృతిహా"},"p2":{"sa":"पुण्यो दुःस्वप्ननाशनः","ro":"puṇyo duḥsvapnanāśanaḥ","te":"పుణ్యో దుఃస్వప్ననాశనః"},"p3":{"sa":"वीरहा रक्षणः सन्तः","ro":"Vīrahā rakṣaṇaḥ santaḥ","te":"వీరహా రక్షణః సన్తః"},"p4":{"sa":"जीवनः पर्यवस्थितः","ro":"jīvanaḥ paryavasthitaḥ","te":"జీవనః పర్యవస్థితః"}},{"s":100,"p1":{"sa":"अनन्तरूपोऽनन्तश्रीः","ro":"Anantarūpo'nantaśrīḥ","te":"అనన్తరూపోఽనన్తశ్రీః"},"p2":{"sa":"जितमन्युर्भयापहः","ro":"jitamanyurbhayāpahaḥ","te":"జితమన్యుర్భయాపహః"},"p3":{"sa":"चतुरश्रो गभीरात्मा","ro":"Caturaśro gabhīrātmā","te":"చతురశ్రో గభీరాత్మా"},"p4":{"sa":"विदिशो व्यादिशो दिशः","ro":"vidiśo vyādiśo diśaḥ","te":"విదిశో వ్యాదిశో దిశః"}},{"s":101,"p1":{"sa":"अनादिर्भूर्भुवो लक्ष्मीः","ro":"Anādirbhūrbhuvo lakṣmīḥ","te":"అనాదిర్భూర్భువో లక్ష్మీః"},"p2":{"sa":"सुवीरो रुचिराङ्गदः","ro":"suvīro rucirāṅgadaḥ","te":"సువీరో రుచిరాఙ్గదః"},"p3":{"sa":"जननो जनजन्मादिः","ro":"Janano janajanmādiḥ","te":"జననో జనజన్మాదిః"},"p4":{"sa":"भीमो भीमपराक्रमः","ro":"bhīmo bhīmaparākramaḥ","te":"భీమో భీమపరాక్రమః"}},{"s":102,"p1":{"sa":"आधारनिलयोऽधाता","ro":"Ādhāranilayo'dhātā","te":"ఆధారనిలయోఽధాతా"},"p2":{"sa":"पुष्पहासः प्रजागरः","ro":"puṣpahāsaḥ prajāgaraḥ","te":"పుష్పహాసః ప్రజాగరః"},"p3":{"sa":"ऊर्ध्वगः सत्पथाचारः","ro":"Ūrdhvagaḥ satpathācāraḥ","te":"ఊర్ధ్వగః సత్పథాచారః"},"p4":{"sa":"प्राणदः प्रणवः पणः","ro":"prāṇadaḥ praṇavaḥ paṇaḥ","te":"ప్రాణదః ప్రణవః పణః"}},{"s":103,"p1":{"sa":"प्रमाणं प्राणनिलयः","ro":"Pramāṇaṃ prāṇanilayaḥ","te":"ప్రమాణం ప్రాణనిలయః"},"p2":{"sa":"प्राणभृत्प्राणजीवनः","ro":"prāṇabhṛtprāṇajīvanaḥ","te":"ప్రాణభృత్ప్రాణజీవనః"},"p3":{"sa":"तत्त्वं तत्त्वविदेकात्मा","ro":"Tattvaṃ tattvavidekātmā","te":"తత్త్వం తత్త్వవిదేకాత్మా"},"p4":{"sa":"जन्ममृत्युजरातिगः","ro":"janmamṛtyujarātigaḥ","te":"జన్మమృత్యుజరాతిగః"}},{"s":104,"p1":{"sa":"भूर्भुवः स्वस्तरुस्तारः","ro":"Bhūrbhuvaḥ svastarustāraḥ","te":"భూర్భువః స్వస్తరుస్తారః"},"p2":{"sa":"सविता प्रपितामहः","ro":"savitā prapitāmahaḥ","te":"సవితా ప్రపితామహః"},"p3":{"sa":"यज्ञो यज्ञपतिर्यज्वा","ro":"Yajño yajñapatiryajvā","te":"యజ్ఞో యజ్ఞపతిర్యజ్వా"},"p4":{"sa":"यज्ञाङ्गो यज्ञवाहनः","ro":"yajñāṅgo yajñavāhanaḥ","te":"యజ్ఞాఙ్గో యజ్ఞవాహనః"}},{"s":105,"p1":{"sa":"यज्ञभृद् यज्ञकृद् यज्ञी","ro":"Yajñabhṛd yajñakṛd yajñī","te":"యజ్ఞభృద్ యజ్ఞకృద్ యజ్ఞీ"},"p2":{"sa":"यज्ञभुग् यज्ञसाधनः","ro":"yajñabhug yajñasādhanaḥ","te":"యజ్ఞభుగ్ యజ్ఞసాధనః"},"p3":{"sa":"यज्ञान्तकृद् यज्ञगुह्यम्","ro":"Yajñāntakṛd yajñaguhyam","te":"యజ్ఞాన్తకృద్ యజ్ఞగుహ్యమ్"},"p4":{"sa":"अन्नमन्नाद एव च","ro":"annamannāda eva ca","te":"అన్నమన్నాద ఏవ చ"}},{"s":106,"p1":{"sa":"आत्मयोनिः स्वयञ्जातः","ro":"Ātmayoniḥ svayañjātaḥ","te":"ఆత్మయోనిః స్వయఞ్జాతః"},"p2":{"sa":"वैखानः सामगायनः","ro":"vaikhānaḥ sāmagāyanaḥ","te":"వైఖానః సామగాయనః"},"p3":{"sa":"देवकीनन्दनः स्रष्टा","ro":"Devakīnandanaḥ sraṣṭā","te":"దేవకీనన్దనః స్రష్టా"},"p4":{"sa":"क्षितीशः पापनाशनः","ro":"kṣitīśaḥ pāpanāśanaḥ","te":"క్షితీశః పాపనాశనః"}},{"s":107,"p1":{"sa":"शङ्खभृन्नन्दकी चक्री","ro":"Śaṅkhabhṛnnandakī cakrī","te":"శఙ్ఖభృన్నన్దకీ చక్రీ"},"p2":{"sa":"शार्ङ्गधन्वा गदाधरः","ro":"śārṅgadhanvā gadādharaḥ","te":"శార్ఙ్గధన్వా గదాధరః"},"p3":{"sa":"रथाङ्गपाणिरक्षोभ्यः","ro":"Rathāṅgapāṇirakṣobhyaḥ","te":"రథాఙ్గపాణిరక్షోభ్యః"},"p4":{"sa":"सर्वप्रहरणायुधः","ro":"sarvapraharaṇāyudhaḥ","te":"సర్వప్రహరణాయుధః"}},{"s":108,"p1":{"sa":"वनमाली गदी शार्ङ्ग","ro":"Vanamālī gadī śārṅga","te":"వనమాలీ గదీ శార్ఙ్గ"},"p2":{"sa":"शङ्खी चक्री च नन्दकी","ro":"śaṅkhī cakrī ca nandakī","te":"శఙ్ఖీ చక్రీ చ నన్దకీ"},"p3":{"sa":"श्रीमान् नारायणो विष्णुः","ro":"Śrīmān nārāyaṇo viṣṇuḥ","te":"శ్రీమాన్ నారాయణో విష్ణుః"},"p4":{"sa":"वासुदेवोऽभिरक्षतु","ro":"vāsudevo'bhirakṣatu","te":"వాసుదేవోఽభిరక్షతు"}}]}